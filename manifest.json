{
  "manifest_version": 3,
  "name": "Aura Inspector Extension",
  "version": "0.5.0",
  "description": "Security auditing tool for Salesforce Experience Cloud sites",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "webRequest",
    "scripting"
  ],
  "optional_permissions": [
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/detector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.my.site.com/*",
        "*://*.vf.force.com/*",
        "*://*.my.salesforce-sites.com/*",
        "*://*.my.salesforce.com/*"
      ],
      "js": ["content/context-extractor.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Aura Inspector"
  }
}
